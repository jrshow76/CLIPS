# DB (Supabase 또는 로컬 PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_SCHEMA=footprint
DB_USER=footprint_app
DB_PASSWORD=footprint_pw

# JWT 서명 키 (256비트 이상 랜덤 문자열 권장)
JWT_SECRET=footprint-secret-key-must-be-at-least-256-bits-long-for-hs256

# 카카오 지도 API 키 (https://developers.kakao.com 에서 발급)
KAKAO_MAP_KEY=
