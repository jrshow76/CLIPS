{
  "name": "@tulip/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Tulip+ 디자인 토큰 (컬러·타이포·간격·radius·shadow·motion)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.mjs",
      "require": "./dist/tailwind-preset.js"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "files": ["dist", "src/tokens.css"],
  "scripts": {
    "build": "tsup src/index.ts src/tailwind-preset.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/tailwind-preset.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@tulip/eslint-config": "workspace:*",
    "@tulip/tsconfig": "workspace:*",
    "tailwindcss": "^3.4.13",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4"
  }
}
