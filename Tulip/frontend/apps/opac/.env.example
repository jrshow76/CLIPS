# Public (NEXT_PUBLIC_*)
NEXT_PUBLIC_APP_NAME=Tulip+ OPAC
NEXT_PUBLIC_APP_ENV=development

# API Gateway base URL — Phase 1-B 이후 iam-service `/api/v1/auth/*` 및 도메인 API 호출
NEXT_PUBLIC_API_BASE_URL=http://localhost:9100

# Keycloak realm / client (Phase 1-B에서는 iam-service가 BFF로 위임받아 처리)
NEXT_PUBLIC_KEYCLOAK_REALM=tulip
NEXT_PUBLIC_CLIENT_ID=opac-web

# Legacy(호환)
NEXT_PUBLIC_AUTH_ISSUER=http://localhost:8081/realms/tulip
NEXT_PUBLIC_AUTH_CLIENT_ID=opac-web

# refresh 쿠키 이름 — iam-service가 발급하는 HttpOnly 쿠키 키 (백엔드와 합의)
NEXT_PUBLIC_AUTH_COOKIE_NAME=tulip_refresh

NEXT_PUBLIC_DEFAULT_LOCALE=ko-KR
