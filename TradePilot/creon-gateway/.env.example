# =============================================================================
# TradePilot CREON Gateway 환경변수 템플릿 (Windows 호스트 전용)
# 실제 사용 시: cp .env.example .env 후 비밀 값 채우기.
# .env 파일은 절대 커밋하지 않는다 (.gitignore 포함).
# =============================================================================

# ----- 공통 인프라 -----
# 본체와 동일한 Redis (네트워크 연결 가능해야 함)
REDIS_URL=redis://10.0.0.10:6379/0
# 본체와 사전 공유한 API 키 (32바이트 이상 랜덤)
GATEWAY_API_KEY=replace-with-long-random-string

# ----- 게이트웨이 식별 -----
GATEWAY_ID=primary
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=9100

# ----- CREON 모드 (가장 중요) -----
# 모의투자(SIM) 또는 실거래(REAL). 기본은 SIM.
# 실거래 전환은 별도 운영 절차 + PM 승인 + 62_go_live_checklist.md 통과 후에만 변경.
CREON_TRADE_ENV=SIM

# 모의투자/실계좌 식별용 접두사 (대신증권 계좌 체계 기준)
# 운영 환경에서 실제 발급된 계좌의 접두사로 교체
CREON_ACCOUNT_PREFIX_SIM=55
CREON_ACCOUNT_PREFIX_REAL=01

# 현재 활성 계좌번호 (CREON Plus에 로그인된 계좌 중 사용할 번호)
# SIM 모드면 모의투자 계좌, REAL 모드면 실거래 계좌
CREON_ACCOUNT_NO=
CREON_ACCOUNT_KIND=01

# 계좌 비밀번호 (Windows DPAPI로 암호화한 base64 문자열)
# 평문 저장 절대 금지
CREON_PASSWORD_ENCRYPTED=

# ----- 연결 / 헬스 -----
CREON_AUTO_RECONNECT_MAX=3
CREON_HEALTHCHECK_INTERVAL_SEC=5
CREON_CONNECT_RETRY_SEC=2
HEALTHBEAT_INTERVAL_SEC=30

# ----- 시세 / 요청 제한 -----
# CREON 공식 한도: 1초 15건 / 4초 60건. 80% 안전 마진 적용 (12 / 48).
SUBSCRIBE_MAX_CODES=400
RATE_LIMIT_PER_SEC=12
RATE_LIMIT_PER_4SEC=48

# ----- Mock / 개발 -----
# Windows + pywin32 정상 설치 환경에서는 false로 설정해 실제 COM 사용.
# Linux/Mac/CI에서는 자동으로 mock fallback 됨 (CREON_USE_MOCK 무관).
CREON_USE_MOCK=false
CREON_FORCE_MOCK=false

# ----- 멱등성 -----
IDEMPOTENCY_TTL_SEC=600

# ----- 로깅 -----
LOG_LEVEL=INFO
LOG_PATH=C:\tradepilot\logs\gateway.log
