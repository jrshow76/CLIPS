# =============================================================================
# TradePilot Kiwoom Gateway 환경변수 템플릿
# =============================================================================
# 실제 사용 시 본 파일을 복사해 .env 로 저장하고 값을 채워 사용한다.
#   cp .env.example .env
#
# !! 절대 평문 시크릿이 채워진 .env 를 git 에 커밋하지 말 것 !!
# =============================================================================

# ----- Gateway 식별/네트워크 -----
GATEWAY_ID=kiwoom-primary
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=9101

# ----- API Key (백엔드 ↔ 게이트웨이 인증) -----
# 운영 시 32자 이상 랜덤 (openssl rand -hex 32)
GATEWAY_API_KEY=replace-with-long-random-string

# ----- Redis (CREON 게이트웨이와 동일 인스턴스 공유) -----
REDIS_URL=redis://10.0.0.10:6379/0

# ----- 키움 모드 / 계좌 -----
# SIM | REAL  (안전 원칙: 기본은 SIM)
KIWOOM_TRADE_ENV=SIM
KIWOOM_ACCOUNT_NO=
# 계좌 비밀번호는 AES-256-GCM 으로 암호화된 토큰을 저장 (security.aes_encrypt 산출물)
KIWOOM_ACCOUNT_PWD_ENCRYPTED=

# ----- Mock / 개발용 -----
# Windows 호스트가 아닐 때 또는 OCX 미설치 환경에서 mock 자동 사용
KIWOOM_USE_MOCK=true
# 운영 Windows 에서도 점검용으로 강제 mock 사용 시 true
KIWOOM_FORCE_MOCK=false

# ----- 요청 제한 (키움 공식: 초당 5건, 시간당 1000건) -----
RATE_LIMIT_PER_SEC=4
RATE_LIMIT_PER_HOUR=800

# ----- 헬스 / 재연결 -----
KIWOOM_HEALTHCHECK_INTERVAL_SEC=5
KIWOOM_AUTO_RECONNECT_MAX=3
HEALTHBEAT_INTERVAL_SEC=30

# ----- Idempotency -----
IDEMPOTENCY_TTL_SEC=600

# ----- 로깅 -----
LOG_LEVEL=INFO
LOG_PATH=

# ----- Mock tick worker (개발/E2E) -----
MOCK_TICK_ENABLED=true
MOCK_TICK_INTERVAL_SEC=1.0
