# =============================================================================
# TradePilot Backend 환경변수 템플릿
# =============================================================================
# 본 파일을 복사해 backend/.env 로 저장한 뒤 값을 채워 사용한다.
#   cp backend/.env.example backend/.env
#
# !! 절대 평문 시크릿이 채워진 .env 를 git 에 커밋하지 말 것 !!
#   - .gitignore 에 .env 가 포함되어 있는지 반드시 확인
#   - 사전 차단: gitleaks pre-commit hook + CI gitleaks job
#   - 회전 및 누출 사고 대응 절차: docs/43_secrets_management.md
#                              security/73_secrets_policy.md
#
# 운영 시 강한 시크릿 생성 명령(반드시 이 파일의 placeholder 를 교체할 것):
#   JWT_SECRET / CREON_GATEWAY_API_KEY:  openssl rand -hex 32
#   AES_KEY                          :  openssl rand -base64 32
#   POSTGRES_PASSWORD                :  openssl rand -hex 24
#
# 운영 환경(APP_ENV=production)에서는 backend/app/core/config.py 의
# _validate_production_settings() 가 약한 시크릿/개발 호스트/와일드카드 CORS
# 등을 감지하면 fail-fast 로 기동을 차단한다.
# =============================================================================

# ----- 애플리케이션 -----
APP_ENV=development              # development | staging | production | test
APP_NAME=tradepilot
APP_TIMEZONE=Asia/Seoul
LOG_LEVEL=INFO
SERVICE_ROLE=api                 # api | worker | scheduler

# ----- 서버 -----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1

# ----- CORS -----
# 운영 환경: 정식 도메인만, 와일드카드(*) 절대 금지. 콤마로 다중 origin 구분.
# 예: https://app.tradepilot.example.com,https://admin.tradepilot.example.com
CORS_ORIGINS=http://localhost:3000

# ----- PostgreSQL -----
# 운영 환경: localhost / 127.0.0.1 / postgres 등 개발 호스트명 사용 금지
# 운영 패스워드 생성: openssl rand -hex 24
DATABASE_URL=postgresql+asyncpg://tradepilot:tradepilot@localhost:5432/tradepilot
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_ECHO=false                    # 운영 환경에서 반드시 false (SQL 평문 로그 차단)

# ----- Redis -----
# DB 0: 캐시, DB 1: Celery 브로커, DB 2: Celery 결과 백엔드
# 운영 환경: localhost / redis 등 개발 호스트명 사용 금지
REDIS_URL=redis://localhost:6379/0
REDIS_BROKER_URL=redis://localhost:6379/1
REDIS_RESULT_URL=redis://localhost:6379/2

# ----- JWT -----
# 운영 시 32자 이상 랜덤 (고유문자 >= 16) — 약한 값이면 부팅 시 fail-fast
# 생성:  openssl rand -hex 32
# 회전 주기: 90일 (docs/43_secrets_management.md)
JWT_SECRET=change-this-in-production-please-32bytes-min
JWT_ALGORITHM=HS256              # HS256/HS384/HS512/RS256/RS384/RS512 만 허용
JWT_ACCESS_TTL_SEC=1800          # 30분
JWT_REFRESH_TTL_SEC=604800       # 7일

# ----- 암호화 (CREON 계좌 비밀번호 등) -----
# AES-256 키, 운영 시 32바이트 base64
# 생성:  openssl rand -base64 32
# 회전 주기: 1년 (기존 암호화 데이터 재암호화 필요 — docs/43_secrets_management.md §4.2)
AES_KEY=base64-encoded-32byte-random-key

# ----- 크레온 게이트웨이 (별도 Windows 호스트) -----
CREON_GATEWAY_URL=http://localhost:9100
# 운영 시 32자 이상 랜덤
# 생성:  openssl rand -hex 32
# 회전 주기: 180일
CREON_GATEWAY_API_KEY=replace-with-long-random-string
CREON_GATEWAY_TIMEOUT_SEC=5.0

# ----- SMTP (선택) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
# 운영 시 빈 값(SMTP 미사용) 또는 강한 시크릿
SMTP_PASSWORD=
SMTP_FROM=TradePilot <noreply@example.com>
SMTP_USE_TLS=true

# ----- 텔레그램 알림 (선택) -----
TELEGRAM_BOT_TOKEN=

# ----- 시세 백업 소스 -----
FALLBACK_QUOTE_ENABLED=true
FALLBACK_QUOTE_SOURCE=naver

# ----- ML -----
ML_MODEL_DIR=/var/lib/tradepilot/models
ML_RETRAIN_HOUR_KST=18

# ----- RateLimit -----
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_QUOTE_PER_SEC=10
RATE_LIMIT_ORDER_PER_SEC=3
RATE_LIMIT_ORDER_PER_DAY=1000
RATE_LIMIT_DEFAULT_PER_MIN=600

# ----- OTP -----
OTP_LENGTH=6
OTP_TTL_SEC=300                  # 5분
OTP_MAX_ATTEMPTS=5

# ----- 멱등성 -----
IDEMPOTENCY_TTL_SEC=86400        # 24시간

# ----- 관측 -----
SENTRY_DSN=
PROMETHEUS_ENABLED=false
