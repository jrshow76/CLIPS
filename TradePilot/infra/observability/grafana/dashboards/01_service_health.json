        { "expr": "sum(rate(http_requests_total{job=\"backend-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"backend-api\"}[5m]))", "refId": "A" }
      ],
      "title": "5xx 에러율 (5m)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tradepilot-prometheus" },
