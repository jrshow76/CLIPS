        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"backend-api\"}[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "title": "API 응답시간 분포 (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tradepilot-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
