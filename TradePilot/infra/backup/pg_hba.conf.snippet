# =====================================================================
# TradePilot pg_hba.conf 권장 스니펫 (백업 + 복제용)
# 적용 위치: $PGDATA/pg_hba.conf 의 적절한 위치
# 적용 후: pg_ctl reload  (또는 SELECT pg_reload_conf())
# =====================================================================
# TYPE  DATABASE        USER            ADDRESS                 METHOD

# ---------------------------------------------------------------------
# 1. 로컬 백업 (peer 인증, OS 사용자 = postgres)
# ---------------------------------------------------------------------
local   all             postgres                                peer
local   all             backup_user                             scram-sha-256

# ---------------------------------------------------------------------
# 2. Docker Compose 내부 (172.16/12 사설망)
# ---------------------------------------------------------------------
host    tradepilot      tradepilot      172.16.0.0/12           scram-sha-256
host    tradepilot      backup_user     172.16.0.0/12           scram-sha-256

# ---------------------------------------------------------------------
# 3. 백업 컨테이너(사이드카) 전용 (호스트 IP 또는 docker network)
# ---------------------------------------------------------------------
host    tradepilot      backup_user     10.0.0.0/8              scram-sha-256

# ---------------------------------------------------------------------
# 4. 스트리밍 복제 (standby 서버 IP 화이트리스트)
# ---------------------------------------------------------------------
host    replication     backup_user     10.10.10.0/24           scram-sha-256
# host  replication     backup_user     standby01.tradepilot     scram-sha-256

# ---------------------------------------------------------------------
# 5. 운영 네트워크 (관리자 접근, VPN/Bastion 통해서만)
# ---------------------------------------------------------------------
host    all             app_admin       192.168.100.0/24        scram-sha-256

# ---------------------------------------------------------------------
# 거부 규칙 (마지막에 위치)
# ---------------------------------------------------------------------
# host  all             all             0.0.0.0/0               reject
