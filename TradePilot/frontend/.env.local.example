# 백엔드 API base URL (서버사이드 rewrite + 클라이언트 직접 호출 양쪽에서 사용)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# 실시간 시세/시그널 WebSocket
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# Mock 모드(백엔드 미가용 시 정적 데이터 사용)
NEXT_PUBLIC_USE_MOCK=true

# 환경 식별
NEXT_PUBLIC_APP_ENV=development

# 클라이언트 측 trace ID 접두사 (선택)
NEXT_PUBLIC_TRACE_PREFIX=tp-web
