# =============================================================================
# TradePilot 환경변수 템플릿 (루트 / docker-compose)
# =============================================================================
# 실제 사용 시 본 파일을 복사해 .env 로 저장하고 값을 채워 사용한다.
#   cp .env.example .env
#
# !! 절대 평문 시크릿이 채워진 .env 를 git 에 커밋하지 말 것 !!
#   - .gitignore 에 .env 가 포함되어 있는지 반드시 확인
#   - 사전 차단: gitleaks pre-commit hook + CI gitleaks job
#   - 회전 및 누출 사고 대응 절차: docs/43_secrets_management.md
#                              security/73_secrets_policy.md
#
# 운영 시 강한 시크릿 생성 명령(반드시 이 파일의 placeholder 를 교체할 것):
#   JWT_SECRET / CREON_GATEWAY_API_KEY:  openssl rand -hex 32
#   AES_KEY                          :  openssl rand -base64 32
#   POSTGRES_PASSWORD                :  openssl rand -hex 24
#
# 운영 환경(APP_ENV=production)에서는 backend/app/core/config.py 의
# _validate_production_settings() 가 약한 시크릿/개발 호스트/와일드카드 CORS
# 등을 감지하면 fail-fast 로 기동을 차단한다.
# =============================================================================

# ----- 애플리케이션 -----
APP_ENV=development              # development | staging | production | test
APP_NAME=tradepilot
APP_TIMEZONE=Asia/Seoul
LOG_LEVEL=INFO

# ----- 포트 (호스트 노출) -----
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ----- PostgreSQL -----
POSTGRES_USER=tradepilot
# 운영 시 32자 이상 랜덤
# 생성:  openssl rand -hex 24
# 회전 주기: 180일
POSTGRES_PASSWORD=tradepilot
POSTGRES_DB=tradepilot

# ----- Redis -----
# DB 0: 캐시, DB 1: Celery 브로커, DB 2: Celery 결과 백엔드
# 운영 환경: localhost / redis 등 개발 호스트명 사용 금지(사설망 IP 또는 정식 도메인)
REDIS_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/1
REDIS_RESULT_URL=redis://redis:6379/2

# ----- JWT -----
# 운영 시 32자 이상 랜덤 (고유문자 >= 16) — 약한 값이면 부팅 시 fail-fast
# 생성:  openssl rand -hex 32
# 회전 주기: 90일 (docs/43_secrets_management.md)
JWT_SECRET=change-this-in-production-please-32bytes-min
JWT_ALGORITHM=HS256              # HS256/HS384/HS512/RS256/RS384/RS512 만 허용
JWT_ACCESS_TTL_SEC=1800          # 30분
JWT_REFRESH_TTL_SEC=604800       # 7일

# ----- 암호화 (계좌 비밀번호 등) -----
# AES-256 키 (32바이트 base64)
# 생성:  openssl rand -base64 32
# 회전 주기: 1년 (기존 암호화 데이터 재암호화 필요 — docs/43_secrets_management.md §4.2)
AES_KEY=base64-encoded-32byte-random-key

# ----- 크레온 게이트웨이 (별도 Windows 호스트) -----
# Linux 메인 서버에서 Windows 호스트로 접근하는 URL
CREON_GATEWAY_URL=http://10.0.0.20:9100
# 운영 시 32자 이상 랜덤
# 생성:  openssl rand -hex 32
# 회전 주기: 180일
CREON_GATEWAY_API_KEY=replace-with-long-random-string
CREON_GATEWAY_TIMEOUT_SEC=5

# ----- SMTP (알림: 이메일) -----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
# 운영 시 빈 값(SMTP 미사용) 또는 강한 시크릿
SMTP_PASSWORD=change-me
SMTP_FROM=TradePilot <noreply@example.com>
SMTP_USE_TLS=true

# ----- 텔레그램 알림 (선택) -----
TELEGRAM_BOT_TOKEN=

# ----- 프론트엔드 (Next.js 빌드 시 인라인) -----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SENTRY_DSN=

# ----- 운영/모니터링 (옵션) -----
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ----- 시세 백업 소스 -----
FALLBACK_QUOTE_ENABLED=true
FALLBACK_QUOTE_SOURCE=naver

# ----- ML -----
ML_MODEL_DIR=/var/lib/tradepilot/models
ML_RETRAIN_HOUR_KST=18

# ----- RateLimit (기본값, 운영에서 조정 가능) -----
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_QUOTE_PER_SEC=10
RATE_LIMIT_ORDER_PER_SEC=3
RATE_LIMIT_ORDER_PER_DAY=1000
RATE_LIMIT_DEFAULT_PER_MIN=600

# =============================================================================
# 알림 채널 (이메일/카카오 알림톡/SMS)
# =============================================================================
# SMTP 보강 항목 (위쪽 SMTP_* 와 일관) - 발신자 표시 이메일/원격 호스트 변수
SMTP_FROM_EMAIL=noreply@tradepilot.example.com

# 카카오 알림톡 (NHN Cloud Notification Service 가정)
# 콘솔: https://console.nhncloud.com/Notification/KakaoTalk
# 운영 시 콘솔에서 발급된 AppKey/SecretKey/SenderKey 사용 (각 32자 이상)
KAKAO_BIZ_API_URL=https://api-alimtalk.cloud.toast.com/alimtalk/v2.3
KAKAO_BIZ_APP_KEY=
KAKAO_BIZ_SECRET=
KAKAO_BIZ_SENDER_KEY=
# OAuth 토큰 모드 사용 시 true (NHN Cloud 는 secret-key 직사용이므로 기본 false)
KAKAO_BIZ_USE_OAUTH=false

# SMS (aws_sns | nhn_cloud)
# 운영 정책: 한국 한정(KR), 발신번호는 사전 등록된 번호만 허용
SMS_PROVIDER=nhn_cloud
SMS_FROM_NUMBER=
# NHN Cloud SMS
SMS_NHN_API_URL=https://api-sms.cloud.toast.com/sms/v3.0
SMS_NHN_APP_KEY=
SMS_NHN_SECRET=
# AWS SNS (대안)
SMS_AWS_ACCESS_KEY=
SMS_AWS_SECRET_KEY=
SMS_AWS_REGION=ap-northeast-2

# 일일 리포트 발송 시각 (KST, 0~23)
NOTIFICATION_DAILY_REPORT_HOUR=18
