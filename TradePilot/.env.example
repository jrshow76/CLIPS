# =============================================================================
# TradePilot 환경변수 템플릿 (루트 / docker-compose)
# =============================================================================
# 실제 사용 시 본 파일을 복사해 .env 로 저장하고 값을 채워 사용한다.
#   cp .env.example .env
#
# !! 절대 평문 시크릿이 채워진 .env 를 git 에 커밋하지 말 것 !!
#   - .gitignore 에 .env 가 포함되어 있는지 반드시 확인
#   - 사전 차단: gitleaks pre-commit hook + CI gitleaks job
#   - 회전 및 누출 사고 대응 절차: docs/43_secrets_management.md
#                              security/73_secrets_policy.md
#
# 운영 시 강한 시크릿 생성 명령(반드시 이 파일의 placeholder 를 교체할 것):
#   JWT_SECRET / CREON_GATEWAY_API_KEY:  openssl rand -hex 32
#   AES_KEY                          :  openssl rand -base64 32
#   POSTGRES_PASSWORD                :  openssl rand -hex 24
#
# 운영 환경(APP_ENV=production)에서는 backend/app/core/config.py 의
# _validate_production_settings() 가 약한 시크릿/개발 호스트/와일드카드 CORS
# 등을 감지하면 fail-fast 로 기동을 차단한다.
# =============================================================================

# ----- 애플리케이션 -----
APP_ENV=development              # development | staging | production | test
APP_NAME=tradepilot
APP_TIMEZONE=Asia/Seoul
LOG_LEVEL=INFO

# ----- 포트 (호스트 노출) -----
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ----- PostgreSQL -----
POSTGRES_USER=tradepilot
# 운영 시 32자 이상 랜덤
# 생성:  openssl rand -hex 24
# 회전 주기: 180일
POSTGRES_PASSWORD=tradepilot
POSTGRES_DB=tradepilot

# ----- Redis -----
# DB 0: 캐시, DB 1: Celery 브로커, DB 2: Celery 결과 백엔드
# 운영 환경: localhost / redis 등 개발 호스트명 사용 금지(사설망 IP 또는 정식 도메인)
REDIS_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/1
REDIS_RESULT_URL=redis://redis:6379/2

# ----- JWT -----
# 운영 시 32자 이상 랜덤 (고유문자 >= 16) — 약한 값이면 부팅 시 fail-fast
# 생성:  openssl rand -hex 32
# 회전 주기: 90일 (docs/43_secrets_management.md)
JWT_SECRET=change-this-in-production-please-32bytes-min
JWT_ALGORITHM=HS256              # HS256/HS384/HS512/RS256/RS384/RS512 만 허용
JWT_ACCESS_TTL_SEC=1800          # 30분
JWT_REFRESH_TTL_SEC=604800       # 7일

# ----- 암호화 (계좌 비밀번호 등) -----
# AES-256 키 (32바이트 base64)
# 생성:  openssl rand -base64 32
# 회전 주기: 1년 (기존 암호화 데이터 재암호화 필요 — docs/43_secrets_management.md §4.2)
AES_KEY=base64-encoded-32byte-random-key

# ----- 크레온 게이트웨이 (별도 Windows 호스트) -----
# Linux 메인 서버에서 Windows 호스트로 접근하는 URL
CREON_GATEWAY_URL=http://10.0.0.20:9100
# 운영 시 32자 이상 랜덤
# 생성:  openssl rand -hex 32
# 회전 주기: 180일
CREON_GATEWAY_API_KEY=replace-with-long-random-string
CREON_GATEWAY_TIMEOUT_SEC=5

# ----- SMTP (알림: 이메일) -----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
# 운영 시 빈 값(SMTP 미사용) 또는 강한 시크릿
SMTP_PASSWORD=change-me
SMTP_FROM=TradePilot <noreply@example.com>
SMTP_USE_TLS=true

# ----- 텔레그램 알림 (선택) -----
TELEGRAM_BOT_TOKEN=

# ----- 프론트엔드 (Next.js 빌드 시 인라인) -----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SENTRY_DSN=

# ----- 운영/모니터링 (옵션) -----
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ----- 시세 백업 소스 -----
FALLBACK_QUOTE_ENABLED=true
FALLBACK_QUOTE_SOURCE=naver

# ----- ML -----
ML_MODEL_DIR=/var/lib/tradepilot/models
ML_RETRAIN_HOUR_KST=18

# ----- RateLimit (기본값, 운영에서 조정 가능) -----
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_QUOTE_PER_SEC=10
RATE_LIMIT_ORDER_PER_SEC=3
RATE_LIMIT_ORDER_PER_DAY=1000
RATE_LIMIT_DEFAULT_PER_MIN=600

# =============================================================================
# 알림 채널 (이메일/카카오 알림톡/SMS)
# =============================================================================
# SMTP 보강 항목 (위쪽 SMTP_* 와 일관) - 발신자 표시 이메일/원격 호스트 변수
SMTP_FROM_EMAIL=noreply@tradepilot.example.com

# 카카오 알림톡 (NHN Cloud Notification Service 가정)
# 콘솔: https://console.nhncloud.com/Notification/KakaoTalk
# 운영 시 콘솔에서 발급된 AppKey/SecretKey/SenderKey 사용 (각 32자 이상)
KAKAO_BIZ_API_URL=https://api-alimtalk.cloud.toast.com/alimtalk/v2.3
KAKAO_BIZ_APP_KEY=
KAKAO_BIZ_SECRET=
KAKAO_BIZ_SENDER_KEY=
# OAuth 토큰 모드 사용 시 true (NHN Cloud 는 secret-key 직사용이므로 기본 false)
KAKAO_BIZ_USE_OAUTH=false

# SMS (aws_sns | nhn_cloud)
# 운영 정책: 한국 한정(KR), 발신번호는 사전 등록된 번호만 허용
SMS_PROVIDER=nhn_cloud
SMS_FROM_NUMBER=
# NHN Cloud SMS
SMS_NHN_API_URL=https://api-sms.cloud.toast.com/sms/v3.0
SMS_NHN_APP_KEY=
SMS_NHN_SECRET=
# AWS SNS (대안)
SMS_AWS_ACCESS_KEY=
SMS_AWS_SECRET_KEY=
SMS_AWS_REGION=ap-northeast-2

# 일일 리포트 발송 시각 (KST, 0~23)
NOTIFICATION_DAILY_REPORT_HOUR=18

# =============================================================================
# Web Push (VAPID) — PWA 푸시 알림
# =============================================================================
# 키 생성:  python scripts/generate_vapid_keys.py
#   - 한 번 생성하여 운영/스테이징/개발 환경별로 키쌍을 따로 관리한다.
#   - 키 회전 정책: 1년 (회전 시 모든 활성 구독이 무효화되므로 신중)
#   - PRIVATE_KEY 는 절대 클라이언트에 노출 금지. PUBLIC_KEY 만 구독 단계에서 전달.
#   - SUBJECT 는 mailto: 또는 https:// 로 시작 (브라우저가 검증)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tradepilot.example.com

# 푸시 메시지 TTL (초) — 디바이스가 오프라인이어도 이 시간까지는 큐잉
WEBPUSH_TTL_SECONDS=86400
# notificationclick 기본 진입 URL
WEBPUSH_DEFAULT_URL=/notifications

# =============================================================================
# D2 - 익스포트(CSV/XLSX) + S3 업로드
# =============================================================================
# S3 호환 오브젝트 스토리지 설정. AWS S3 / MinIO / Cloudflare R2 등에서 사용.
# 운영에서는 IAM Role 사용을 권장하며, 그 경우 ACCESS/SECRET 키 비워둔다.
EXPORT_S3_BUCKET=tradepilot-exports
EXPORT_S3_REGION=ap-northeast-2
# 키 prefix. 사용자별 버킷 분리 대신 path 분리 사용.
# 최종 키 형식: {prefix}{user_id}/{public_id}.{csv|xlsx}
EXPORT_S3_PREFIX=exports/
# MinIO/R2 등 호환 스토리지 사용 시 엔드포인트 지정. AWS S3 사용 시 비워둔다.
EXPORT_S3_ENDPOINT_URL=
# AWS 자격증명 (IAM Role 사용 시 비워둔다)
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY 는 boto3 표준 환경변수
# 익스포트 파일 보관 시간(시간 단위). 기본 168h(7일).
EXPORT_TTL_HOURS=168
# 사전서명 URL TTL(초). 기본 3600(1시간).
EXPORT_PRESIGN_TTL_SECONDS=3600
# 단일 익스포트 최대 행수
EXPORT_MAX_ROWS=1000000
# 청크 처리 크기 (pandas iterator)
EXPORT_CHUNK_SIZE=50000
# 멀티파트 업로드 임계치(MB)
EXPORT_MULTIPART_THRESHOLD_MB=10
# 사용자당 동시 PENDING/RUNNING 익스포트 최대
EXPORT_CONCURRENT_PER_USER=3
# 사용자당 일일 신규 요청 최대
EXPORT_DAILY_LIMIT_PER_USER=20


# =============================================================================
# D4 — 다증권사 어댑터 (KIS / 키움)
# =============================================================================
# 시스템 기본 증권사 (사용자 미설정 시 사용). CREON | KIS | KIWOOM
DEFAULT_BROKER=CREON

# Fallback 정책: 주 broker 게이트웨이 장애(E0012/E0072/E0004) 시 백업으로 1회 재시도
BROKER_FALLBACK_ENABLED=false
BROKER_FALLBACK_BACKUP=KIS

# ----- 한국투자증권 (KIS) Open API -----
# 신청: https://apiportal.koreainvestment.com  (APPKEY/APPSECRET 발급, 24h 토큰)
# 운영(REAL) / 모의(SIM) 도메인 분리 — SIM 환경은 별도 사이트에서 모의계좌 발급
KIS_API_URL_REAL=https://openapi.koreainvestment.com:9443
KIS_API_URL_SIM=https://openapivts.koreainvestment.com:29443
KIS_WS_URL_REAL=ws://ops.koreainvestment.com:21000
KIS_WS_URL_SIM=ws://ops.koreainvestment.com:31000
# 시스템 기본 자격증명 (개별 사용자 자격증명은 DB broker_credentials JSONB에 AES 암호화 저장)
KIS_APPKEY=
KIS_APPSECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PROD_CD=01
# SIM | REAL
KIS_TRADE_ENV=SIM
KIS_TIMEOUT_SEC=5.0
# KIS 공식 한도: 초당 약 20건 — 안전 마진 80% 적용
KIS_RATE_LIMIT_PER_SEC=16
# 토큰은 24시간(86400초) 만료 — 1시간 사전 마진 적용 시 23h
KIS_TOKEN_CACHE_TTL_SEC=82800

# ----- 키움 OpenAPI+ (Windows 게이트웨이 — kiwoom-gateway/) -----
KIWOOM_GATEWAY_URL=http://10.0.0.21:9101
# 운영 시 32자 이상 랜덤 (openssl rand -hex 32). kiwoom-gateway/.env 의 GATEWAY_API_KEY 와 동일 값.
KIWOOM_GATEWAY_API_KEY=replace-with-long-random-string
KIWOOM_GATEWAY_TIMEOUT_SEC=5
