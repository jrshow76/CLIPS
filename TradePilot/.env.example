# =============================================================================
# TradePilot 환경변수 템플릿
# 실제 사용 시 본 파일을 복사해 .env로 저장하고 값을 채워 사용한다.
#   cp .env.example .env
# .env 파일은 절대 커밋하지 않는다 (.gitignore에 포함).
# =============================================================================

# ----- 애플리케이션 -----
APP_ENV=development
APP_NAME=tradepilot
APP_TIMEZONE=Asia/Seoul
LOG_LEVEL=INFO

# ----- 포트 (호스트 노출) -----
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ----- PostgreSQL -----
POSTGRES_USER=tradepilot
POSTGRES_PASSWORD=tradepilot
POSTGRES_DB=tradepilot

# ----- Redis -----
# DB 0: 캐시, DB 1: Celery 브로커, DB 2: Celery 결과 백엔드
REDIS_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/1
REDIS_RESULT_URL=redis://redis:6379/2

# ----- JWT -----
# JWT_SECRET은 운영 환경에서 반드시 32바이트 이상의 랜덤 문자열로 교체할 것
JWT_SECRET=change-this-in-production-please-32bytes-min
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SEC=1800        # 30분
JWT_REFRESH_TTL_SEC=604800     # 7일

# ----- 암호화 (계좌 비밀번호 등) -----
# AES-256 키 (32바이트 base64)
AES_KEY=base64-encoded-32byte-random-key

# ----- 크레온 게이트웨이 (별도 Windows 호스트) -----
# Linux 메인 서버에서 Windows 호스트로 접근하는 URL
CREON_GATEWAY_URL=http://10.0.0.20:9100
CREON_GATEWAY_API_KEY=replace-with-long-random-string
CREON_GATEWAY_TIMEOUT_SEC=5

# ----- SMTP (알림: 이메일) -----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=TradePilot <noreply@example.com>
SMTP_USE_TLS=true

# ----- 텔레그램 알림 (선택) -----
TELEGRAM_BOT_TOKEN=

# ----- 프론트엔드 (Next.js 빌드 시 인라인) -----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SENTRY_DSN=

# ----- 운영/모니터링 (옵션) -----
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ----- 시세 백업 소스 -----
FALLBACK_QUOTE_ENABLED=true
FALLBACK_QUOTE_SOURCE=naver

# ----- ML -----
ML_MODEL_DIR=/var/lib/tradepilot/models
ML_RETRAIN_HOUR_KST=18

# ----- RateLimit (기본값, 운영에서 조정 가능) -----
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_QUOTE_PER_SEC=10
RATE_LIMIT_ORDER_PER_SEC=3
RATE_LIMIT_ORDER_PER_DAY=1000
RATE_LIMIT_DEFAULT_PER_MIN=600
