                  "pm.test('imageId 및 URL 반환', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.imageId).to.exist;",
                  "  pm.expect(body.data.url).to.exist;",
                  "  pm.expect(body.data.url).to.include('cdn.shelfy.io');",
