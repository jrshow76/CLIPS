            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "./fixtures/test-image.gif" },
                { "key": "type", "value": "ITEM_IMAGE", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "FILE-E005 Magic Bytes 스푸핑 차단 (확장자 위조)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
