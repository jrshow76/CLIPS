                  "  const start = new Date(body.data.startedAt);",
                  "  const nextBilling = new Date(body.data.nextBillingAt);",
                  "  const expected = new Date(start);",
                  "  expected.setMonth(expected.getMonth() + 1);",
                  "  const diffMs = Math.abs(nextBilling - expected);",
                  "  pm.expect(diffMs).to.be.lessThan(24 * 60 * 60 * 1000);",
