{
  "info": {
    "name": "Shelfy API Test Collection",
    "description": "Shelfy 서비스 API 테스트 컬렉션 (인증 → 파일 → 아이템 → 구매 → 구독 체이닝)\n\n환경 변수:\n- baseUrl: API 서버 기본 URL\n- accessToken: 로그인 후 자동 설정\n- sellerAccessToken: 셀러 계정 토큰\n- buyerAccessToken: 바이어 계정 토큰\n- testItemId: 생성된 상품 ID\n- testOrderId: 생성된 주문 ID\n- testSubscriptionId: 생성된 구독 ID\n- testImageId: 업로드된 이미지 ID",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "sellerAccessToken", "value": "", "type": "string" },
    { "key": "buyerAccessToken", "value": "", "type": "string" },
    { "key": "testItemId", "value": "", "type": "string" },
    { "key": "testPlanId", "value": "", "type": "string" },
    { "key": "testOrderId", "value": "", "type": "string" },
    { "key": "testSubscriptionId", "value": "", "type": "string" },
    { "key": "testImageId", "value": "", "type": "string" },
    { "key": "sellerEmail", "value": "", "type": "string" },
    { "key": "buyerEmail", "value": "", "type": "string" },
    { "key": "testPassword", "value": "Shelfy1234!", "type": "string" }
  ],
  "item": [
    {
      "name": "01. 인증 (AUTH)",
      "item": [
        {
          "name": "AUTH-001 셀러 회원가입",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const timestamp = Date.now();",
                  "const sellerEmail = `seller_${timestamp}@shelfy-test.io`;",
                  "const sellerNick = `seller_${timestamp.toString().slice(-6)}`;",
                  "pm.collectionVariables.set('sellerEmail', sellerEmail);",
                  "pm.collectionVariables.set('sellerNick', sellerNick);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 201 반환', () => {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('응답 구조 검증', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.be.true;",
                  "  pm.expect(body.data.userId).to.exist;",
                  "  pm.expect(body.data.email).to.equal(pm.collectionVariables.get('sellerEmail'));",
                  "  pm.expect(body.data.nickname).to.equal(pm.collectionVariables.get('sellerNick'));",
                  "  pm.expect(body.data.password).to.be.undefined;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sellerEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"passwordConfirm\": \"{{testPassword}}\",\n  \"nickname\": \"{{sellerNick}}\",\n  \"agreeTerms\": true,\n  \"agreePrivacy\": true,\n  \"agreeMarketing\": false\n}"
            }
          }
        },
        {
          "name": "AUTH-002 바이어 회원가입",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const timestamp = Date.now() + 1;",
                  "const buyerEmail = `buyer_${timestamp}@shelfy-test.io`;",
                  "const buyerNick = `buyer_${timestamp.toString().slice(-6)}`;",
                  "pm.collectionVariables.set('buyerEmail', buyerEmail);",
                  "pm.collectionVariables.set('buyerNick', buyerNick);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 201 반환', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{buyerEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"passwordConfirm\": \"{{testPassword}}\",\n  \"nickname\": \"{{buyerNick}}\",\n  \"agreeTerms\": true,\n  \"agreePrivacy\": true,\n  \"agreeMarketing\": false\n}"
            }
          }
        },
        {
          "name": "AUTH-E001 이메일 중복 가입 차단",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 409 반환', () => pm.response.to.have.status(409));",
                  "pm.test('에러 코드 AUTH-E001', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error.code).to.equal('AUTH-E001');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sellerEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"passwordConfirm\": \"{{testPassword}}\",\n  \"nickname\": \"new_unique_nick_999\",\n  \"agreeTerms\": true,\n  \"agreePrivacy\": true\n}"
            }
          }
        },
        {
          "name": "AUTH-003 셀러 로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200 반환', () => pm.response.to.have.status(200));",
                  "pm.test('accessToken 발급', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.accessToken).to.exist;",
                  "  pm.expect(body.data.tokenType).to.equal('Bearer');",
                  "  pm.expect(body.data.expiresIn).to.equal(3600);",
                  "  pm.expect(body.data.refreshToken).to.be.undefined;",
                  "  pm.collectionVariables.set('sellerAccessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "});",
                  "pm.test('refreshToken HttpOnly 쿠키 설정 확인', () => {",
                  "  const setCookie = pm.response.headers.get('Set-Cookie') || '';",
                  "  pm.expect(setCookie.toLowerCase()).to.include('httponly');",
                  "  pm.expect(setCookie).to.include('refreshToken');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sellerEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            }
          }
        },
        {
          "name": "AUTH-004 바이어 로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200 반환', () => pm.response.to.have.status(200));",
                  "pm.test('바이어 accessToken 저장', () => {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('buyerAccessToken', body.data.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{buyerEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            }
          }
        },
        {
          "name": "AUTH-E020 잘못된 비밀번호 로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 401 반환', () => pm.response.to.have.status(401));",
                  "pm.test('에러 코드 AUTH-E020', () => {",
                  "  pm.expect(pm.response.json().error.code).to.equal('AUTH-E020');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sellerEmail}}\",\n  \"password\": \"WrongPass9!\"\n}"
            }
          }
        },
        {
          "name": "AUTH-005 토큰 갱신",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200 반환', () => pm.response.to.have.status(200));",
                  "pm.test('새 accessToken 발급', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.accessToken).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/token/refresh"
          }
        }
      ]
    },
    {
