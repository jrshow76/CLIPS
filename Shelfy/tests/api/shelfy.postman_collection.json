                  "pm.test('에러 코드 ITEM-E002', () => {",
                  "  pm.expect(pm.response.json().error.code).to.equal('ITEM-E002');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerAccessToken}}" }
            ],
            "url": "{{baseUrl}}/files/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "./fixtures/spoofed-script.jpg",
                  "description": "확장자는 .jpg이나 실제 내용은 PHP 스크립트인 파일"
                },
                { "key": "type", "value": "ITEM_IMAGE", "type": "text" }
              ]
            }
          }
        }
      ]
    },
    {
