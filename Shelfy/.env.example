# ===================================================
# Shelfy 환경변수 템플릿
# 이 파일을 .env로 복사한 후 실제 값을 설정하세요.
# .env 파일은 절대 Git에 커밋하지 마세요.
# ===================================================

# ===== Database =====
POSTGRES_DB=shelfy
POSTGRES_USER=shelfy_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_PORT=5432

# ===== JWT =====
# 256비트(32바이트) 이상의 랜덤 문자열 사용 권장
# 생성 명령어: openssl rand -hex 32
JWT_SECRET=your-256-bit-secret-key-here-change-in-production

# ===== MinIO (개발용 Object Storage) =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_BUCKET=shelfy-images

# ===== CDN =====
# 개발: MinIO URL 사용
# 운영: CDN 도메인으로 변경
CDN_BASE_URL=http://localhost:9000/shelfy-images

# ===== Mail (이메일 발송) =====
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
FRONTEND_URL=http://localhost:3000

# ===== Spring Boot =====
SPRING_PROFILES_ACTIVE=default
BACKEND_PORT=8080
FRONTEND_PORT=3000
